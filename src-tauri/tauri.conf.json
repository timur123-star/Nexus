{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexusShield",
  "version": "0.1.0",
  "identifier": "app.nexusshield.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NexusShield",
        "width": 1080,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nexusshield"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/*": "binaries/"
    },
    "category": "Utility",
    "shortDescription": "Universal Xray/Sing-box client",
    "longDescription": "NexusShield — a modern cross-platform client for Xray-core and Sing-box."
  }
}
